# Copia este archivo a .env y ajusta los valores.
# ⚠️ NUNCA commitees el .env real: contiene secretos.

# --- Obligatorias ---

DATABASE_URL="postgresql://usuario:password@localhost:5432/promapp?schema=public"

# Genera uno propio (mínimo 32 caracteres). La app NO arranca con un valor de ejemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# --- Opcionales ---

JWT_EXPIRES_IN="7d"

# El hosting (Railway) inyecta PORT automáticamente. En local, 3000.
PORT=3000

# "production" cierra Swagger (/docs). En local déjalo sin definir.
# NODE_ENV=production

# Orígenes permitidos para CORS, separados por coma. Sin esto se permite
# cualquiera (las apps nativas no aplican CORS; importa en la build web).
# CORS_ORIGINS=https://promapp.tudominio.com

# Fuerza exponer /docs aunque NODE_ENV=production. Úsalo con cuidado.
# ENABLE_DOCS=true
