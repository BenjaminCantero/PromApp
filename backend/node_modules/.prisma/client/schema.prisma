// Prisma schema de PromApp — refleja los modelos de dominio de Flutter.
//
// User 1─* Asignatura 1─* Evaluacion

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String  @id @default(uuid())
  email       String  @unique
  password    String // hash bcrypt
  nombre      String
  carrera     String?
  universidad String?

  asignaturas Asignatura[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Asignatura {
  id       String  @id @default(uuid())
  nombre   String
  codigo   String?
  semestre String?

  // Configuración de examen (por ramo)
  tieneExamen      Boolean @default(false)
  pesoPresentacion Float   @default(0.6)
  pesoExamen       Float   @default(0.4)
  notaExamen       Float?
  notaEximir       Float?

  evaluaciones Evaluacion[]

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("asignaturas")
}

model Evaluacion {
  id         String    @id @default(uuid())
  nombre     String
  porcentaje Float // peso dentro de la presentación (0–100)
  nota       Float? // 1.0–7.0, null si no rendida
  tipo       String?
  fecha      DateTime?

  asignatura   Asignatura @relation(fields: [asignaturaId], references: [id], onDelete: Cascade)
  asignaturaId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([asignaturaId])
  @@map("evaluaciones")
}
